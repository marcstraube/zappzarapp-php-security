{
    "$schema": "https://raw.githubusercontent.com/infection/infection/0.29.0/resources/schema.json",
    "source": {
        "directories": ["src"]
    },
    "logs": {
        "text": "build/infection.log",
        "summary": "build/infection-summary.log"
    },
    "mutators": {
        "@default": true,

        // =============================================
        // Rate-limiting algorithms - mathematical approximations
        // These use floating-point arithmetic that produces equivalent results
        // =============================================
        "RoundingFamily": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\Password\\Strength\\PasswordStrengthMeter::*"
            ]
        },
        "CastInt": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\Password\\Strength\\PasswordStrengthMeter::*",
                // EQUIVALENT on 64-bit PHP: sprintf('%u', $long) returns string,
                // but PHP type juggling converts it to int for comparison with
                // integer constants. Both signed and unsigned values fit in 64-bit int.
                "Zappzarapp\\Security\\Sanitization\\Uri\\PrivateNetworkValidator::isPrivateIpv4"
            ]
        },
        "Division": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\Password\\Strength\\PasswordStrengthMeter::*"
            ]
        },
        "Multiplication": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*"
            ]
        },
        "Plus": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*"
            ]
        },
        "OneZeroFloat": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*"
            ]
        },
        "ArrayOneItem": {
            "ignore": [
                "Zappzarapp\\Security\\Password\\Strength\\PasswordStrengthMeter::*",
                // Returning only first DNS record vs all records - gethostbyname
                // usually provides the primary IP, dns_get_record is for additional IPs.
                // Requires real network with multi-record responses to kill.
                "Zappzarapp\\Security\\Sanitization\\Uri\\NativeDnsResolver::resolveViaDnsGetRecord"
            ]
        },

        // =============================================
        // Exception message formatting - cosmetic only
        // =============================================
        "Ternary": {
            "ignore": [
                "Zappzarapp\\Security\\*\\Exception\\*",
                "Zappzarapp\\Security\\Csrf\\Storage\\ArrayCsrfStorage::store",
                // HTTP context ternary for follow_location flag
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // Normalizer fallback - equivalent, both return the normalized string
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::normalizeForDetection",
                // Rate-limiting algorithms
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*"
            ]
        },
        "TrueValue": {
            "ignore": [
                // HTTP client defaults - operational configuration
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // Config with* methods - tested via behavior, not value
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedCheckerConfig::*",
                // CSRF protection defaults
                "Zappzarapp\\Security\\Csrf\\CsrfProtection::*",
                // Rate-limiting algorithms
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\RateLimiting\\RateLimitResult::*",
                // SRI hash generator
                "Zappzarapp\\Security\\Sri\\SriHashGenerator::*",
                // ResourceFetcherConfig requireHttps default - tested via behavior
                "Zappzarapp\\Security\\Sri\\ResourceFetcherConfig::*"
            ]
        },
        "FalseValue": {
            "ignore": [
                // HTTP client defaults - operational configuration
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // Config with* methods - tested via behavior, not value
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedCheckerConfig::*",
                // URL attribute default - unknown element types should not be URL-sanitized
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::isUrlAttribute",
                // Password strength meter defaults
                "Zappzarapp\\Security\\Password\\Strength\\PasswordStrengthMeter::*",
                // NullCsrfToken - tested via behavior
                "Zappzarapp\\Security\\Csrf\\Token\\NullCsrfToken::*"
            ],
            "ignoreSourceCodeByRegex": [
                ".*allowProduction.*"
            ]
        },
        "Coalesce": {
            "ignore": [
                // HTTP client option handling - defaults tested at integration level
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // Error message fallback
                "Zappzarapp\\Security\\Sri\\ResourceFetcher::fetch",
                // Equivalent: spread operator ...$context overrides the first correlation_id
                "Zappzarapp\\Security\\Logging\\SecurityAuditLogger::enrichContext",
                // Equivalent: preg_replace already handles the case
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::normalizeForDetection",
                // SRI hash generator
                "Zappzarapp\\Security\\Sri\\SriHashGenerator::*",
                // Rate-limiting algorithms
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                // $_SERVER coalesce - environment-dependent, tested via behavior
                "Zappzarapp\\Security\\Cookie\\CookieOptions::appearsToBeHttps",
                // HtmlSanitizer UriSanitizer default - tested via behavior
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::__construct"
            ]
        },
        "Concat": {
            "ignore": [
                "Zappzarapp\\Security\\*\\Exception\\*",
                "Zappzarapp\\Security\\Sri\\IntegrityAttribute::*",
                "Zappzarapp\\Security\\Cookie\\SecureCookie::headerValue",
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*",
                // HTTP header formatting
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // API URL construction and deprecated method messages
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedPasswordChecker::*",
                "Zappzarapp\\Security\\Sanitization\\Sql\\SqlEscaper::*",
                // Exception and log messages - cosmetic only
                "Zappzarapp\\Security\\Csrf\\Storage\\SessionCsrfStorage::*",
                "Zappzarapp\\Security\\Csrf\\Validation\\CsrfValidator::*",
                "Zappzarapp\\Security\\Csrf\\CsrfProtection::*",
                // Rate-limiting key construction
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\RateLimiting\\RateLimitResult::*",
                // MySQL-specific SQL in upsert() — untestable without MySQL
                "Zappzarapp\\Security\\RateLimiting\\Storage\\PdoStorage::upsert"
            ]
        },
        "ConcatOperandRemoval": {
            "ignore": [
                "Zappzarapp\\Security\\*\\Exception\\*",
                "Zappzarapp\\Security\\Sri\\IntegrityAttribute::*",
                "Zappzarapp\\Security\\Cookie\\SecureCookie::headerValue",
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*",
                // HTTP header formatting
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // API URL construction and deprecated method messages
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedPasswordChecker::*",
                "Zappzarapp\\Security\\Sanitization\\Sql\\SqlEscaper::*",
                // Equivalent: DOMDocument handles malformed HTML gracefully
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::parseHtml",
                // Exception and log messages - cosmetic only
                "Zappzarapp\\Security\\Csrf\\Storage\\SessionCsrfStorage::*",
                "Zappzarapp\\Security\\Csrf\\Validation\\CsrfValidator::*",
                "Zappzarapp\\Security\\Csrf\\CsrfProtection::*",
                // Rate-limiting key construction
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\RateLimiting\\RateLimitResult::*",
                // Truncation marker "..." cosmetic
                "Zappzarapp\\Security\\Logging\\SecurityAuditLogger::truncateContext",
                // MySQL-specific SQL in upsert() — untestable without MySQL
                "Zappzarapp\\Security\\RateLimiting\\Storage\\PdoStorage::upsert"
            ]
        },
        "UnwrapArraySlice": {
            "ignore": [
                // Truncation of context keys - defense in depth for DoS prevention
                "Zappzarapp\\Security\\Logging\\SecurityAuditLogger::truncateContext"
            ]
        },
        "UnwrapSubstr": {
            "ignore": [
                "Zappzarapp\\Security\\*\\Exception\\*",
                // HIBP API prefix extraction - RFC defined
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedPasswordChecker::*",
                // EQUIVALENT: $hex vs substr($hex, 24, 8) for IPv4 extraction.
                // Due to long2ip() using only lower 32 bits, the embedded IPv4
                // (at positions 24-31) is preserved even when using full hex.
                // hexdec overflow wraps to the same lower 32 bits.
                "Zappzarapp\\Security\\Sanitization\\Uri\\PrivateNetworkValidator::isPrivateIpv6"
            ]
        },

        // =============================================
        // RFC-defined constants and boundaries
        // Control chars (0-31, 127), tested at integration level
        // =============================================
        "IncrementInteger": {
            "ignore": [
                "Zappzarapp\\Security\\Csp\\Nonce\\NonceGenerator::get",
                "Zappzarapp\\Security\\*\\Exception\\*",
                "Zappzarapp\\Security\\Cookie\\SecureCookie::headerValue",
                "Zappzarapp\\Security\\Cookie\\CookieValidator::*",
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*",
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::*",
                "Zappzarapp\\Security\\Password\\Strength\\PasswordStrengthMeter::*",
                "Zappzarapp\\Security\\Password\\Policy\\PasswordPolicy::*",
                // HIBP API k-anonymity prefix length (5 chars) - RFC defined
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedPasswordChecker::*",
                // HTTP client defaults - operational configuration
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // Rate-limiting algorithms
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\RateLimiting\\DefaultRateLimiter::*",
                // Password hashing
                "Zappzarapp\\Security\\Password\\Hashing\\*",
                // EQUIVALENT: substr($hex, 24, 8) vs substr($hex, 24, 9)
                // IPv6 hex is 32 chars, position 24 has only 8 chars remaining.
                // substr returns available chars when length exceeds remaining.
                "Zappzarapp\\Security\\Sanitization\\Uri\\PrivateNetworkValidator::isPrivateIpv6",
                // EQUIVALENT: explode limit 2 vs 3 - mutant is MORE restrictive,
                // rejects tokens with multiple dots instead of treating extra dots as part of signature
                "Zappzarapp\\Security\\Csrf\\Pattern\\DoubleSubmitCookiePattern::validate"
            ]
        },
        "DecrementInteger": {
            "ignore": [
                "Zappzarapp\\Security\\*\\Exception\\*",
                "Zappzarapp\\Security\\Cookie\\SecureCookie::headerValue",
                "Zappzarapp\\Security\\Cookie\\CookieValidator::*",
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*",
                "Zappzarapp\\Security\\RateLimiting\\RateLimitResult::toHeaders",
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::*",
                "Zappzarapp\\Security\\Password\\Strength\\PasswordStrengthMeter::*",
                "Zappzarapp\\Security\\Password\\Policy\\PasswordPolicy::*",
                // HIBP API k-anonymity prefix length (5 chars) - RFC defined
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedPasswordChecker::*",
                // HTTP client defaults - operational configuration
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // Rate-limiting algorithms
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*"
            ]
        },
        "LessThan": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Storage\\InMemoryStorage::*",
                "Zappzarapp\\Security\\Cookie\\CookieValidator::*",
                "Zappzarapp\\Security\\Csrf\\Storage\\ArrayCsrfStorage::*",
                "Zappzarapp\\Security\\Csrf\\Storage\\SessionCsrfStorage::*",
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::*",
                "Zappzarapp\\Security\\Password\\Strength\\PasswordStrengthMeter::*",
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*",
                // Equivalent: DOMNamedNodeMap iteration - off-by-one guarded by instanceof check
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::sanitizeAttributes",
                // Rate-limiting algorithms
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*"
            ]
        },
        "LessThanOrEqualTo": {
            "ignore": [
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::strengthLevel",
                // Exception truncate boundary - cosmetic
                "Zappzarapp\\Security\\Cookie\\Exception\\InvalidCookieOptionsException::truncate"
            ]
        },
        "GreaterThan": {
            "ignore": [
                "Zappzarapp\\Security\\Cookie\\SecureCookie::headerValue",
                "Zappzarapp\\Security\\*\\Exception\\*",
                "Zappzarapp\\Security\\Cookie\\CookieValidator::*",
                // Size limit comparison
                "Zappzarapp\\Security\\Sri\\ResourceFetcher::*",
                // Rate limit results
                "Zappzarapp\\Security\\RateLimiting\\RateLimitResult::*",
                // Rate-limiting algorithms
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*"
            ]
        },
        "GreaterThanOrEqualTo": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Storage\\InMemoryStorage::*",
                // minOccurrences boundary - tested with exact values
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedPasswordChecker::*",
                // Rate limit
                "Zappzarapp\\Security\\RateLimiting\\DefaultRateLimiter::*",
                // Password strength
                "Zappzarapp\\Security\\Password\\Strength\\*"
            ]
        },
        "GreaterThanOrEqualToNegotiation": {
            "ignore": [
                // InMemoryStorage key limit check - defense in depth
                "Zappzarapp\\Security\\RateLimiting\\Storage\\InMemoryStorage::*"
            ]
        },

        // =============================================
        // Logical expression mutations
        // =============================================
        "LogicalOr": {
            "ignore": [
                "Zappzarapp\\Security\\Csp\\Nonce\\NonceRegistry::validateNonce",
                "Zappzarapp\\Security\\Cookie\\CookieValidator::*",
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*",
                // URL validation
                "Zappzarapp\\Security\\Sri\\ResourceFetcher::*",
                // NullCsrfToken - tests run in test environment, cannot test non-test path
                "Zappzarapp\\Security\\Csrf\\Token\\NullCsrfToken::isTestEnvironment"
            ]
        },
        // MERGED: LogicalOrAllSubExprNegation is defined below with all ignores
        "LogicalAnd": {
            "ignore": [
                "Zappzarapp\\Security\\Headers\\Builder\\SecurityHeadersBuilder::*",
                // checkSymlinksInPath while loop - inner break condition handles all edge cases
                // making the loop condition mutations semantically equivalent
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::checkSymlinksInPath",
                // InMemoryStorage key limit check - defense in depth
                "Zappzarapp\\Security\\RateLimiting\\Storage\\InMemoryStorage::*"
            ]
        },
        "LogicalAndAllSubExprNegation": {
            "ignore": [
                "Zappzarapp\\Security\\Csrf\\Storage\\ArrayCsrfStorage::*",
                "Zappzarapp\\Security\\Cookie\\CookieValidator::*",
                // InMemoryStorage key limit check - defense in depth
                "Zappzarapp\\Security\\RateLimiting\\Storage\\InMemoryStorage::*"
            ]
        },
        "LogicalAndNegation": {
            "ignore": [
                // InMemoryStorage key limit check - defense in depth
                "Zappzarapp\\Security\\RateLimiting\\Storage\\InMemoryStorage::*"
            ]
        },

        // =============================================
        // Defense in Depth - redundant validation
        // =============================================
        "Throw_": {
            "ignore": [
                "Zappzarapp\\Security\\Csp\\Nonce\\NonceRegistry::validateNonce",
                "Zappzarapp\\Security\\Cookie\\CookieValidator::*",
                // URL validation throws
                "Zappzarapp\\Security\\Sri\\ResourceFetcher::*",
                // Blocked scheme handling - tested via expectException
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::validate",
                // IDN validation - defense in depth
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::validateIdnHost"
            ]
        },
        "MethodCallRemoval": {
            "ignore": [
                "Zappzarapp\\Security\\Csp\\Nonce\\NonceRegistry::set",
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*",
                "Zappzarapp\\Security\\RateLimiting\\Storage\\InMemoryStorage::*",
                // Memory clearing is security defense-in-depth, not functionally testable
                "Zappzarapp\\Security\\Password\\Security\\ClearsMemory::*",
                // setAttribute re-assignment - attribute already set by DOMDocument parse
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::*",
                // CSRF token cleanup - defense in depth
                "Zappzarapp\\Security\\Csrf\\Pattern\\SynchronizerTokenPattern::*",
                // Password hashing internals
                "Zappzarapp\\Security\\Password\\Hashing\\*",
                // Rate-limiting algorithms
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                // NonceScope end() calls NonceRegistry::reset() - idempotent cleanup
                "Zappzarapp\\Security\\Csp\\Nonce\\NonceScope::end"
            ]
        },
        // =============================================
        // Entropy calculation - approximate values
        // =============================================
        "Assignment": {
            "ignore": [
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::calculatePoolSize"
            ]
        },
        "PlusEqual": {
            "ignore": [
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::calculatePoolSize"
            ]
        },
        "IfNegation": {
            "ignore": [
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::calculatePoolSize",
                // sodium_memzero availability check - runtime dependent
                "Zappzarapp\\Security\\Password\\Security\\ClearsMemory::clearMemory",
                // normalizer_normalize availability check - runtime dependent
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::normalizeForDetection",
                // Cookie security checks
                "Zappzarapp\\Security\\Cookie\\SecureCookie::*"
            ]
        },
        "CastFloat": {
            "ignore": [
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::calculate",
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\Password\\Strength\\*"
            ]
        },
        "MBString": {
            "ignore": [
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::calculate",
                "Zappzarapp\\Security\\Password\\Strength\\PasswordStrengthMeter::*",
                "Zappzarapp\\Security\\Password\\Policy\\Rules\\*",
                // Logging truncation - mb_strlen vs strlen difference only matters
                // for multi-byte strings, both truncate to same visual length
                "Zappzarapp\\Security\\Logging\\SecurityAuditLogger::truncateContext",
                // SecurityEvent input truncation - cosmetic for logging
                "Zappzarapp\\Security\\Logging\\SecurityEvent::xssBlocked"
            ]
        },
        "ReturnRemoval": {
            "ignore": [
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::calculate",
                "Zappzarapp\\Security\\Password\\Strength\\PasswordStrengthMeter::*",
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::hasBlockedExtension",
                // Storage null returns for missing keys
                "Zappzarapp\\Security\\RateLimiting\\Storage\\RedisStorage::get",
                // Equivalent: empty string early return optimization, code continues to same result
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::sanitize",
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::validate",
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::validateIdnHost",
                // PermissionsPolicy internals
                "Zappzarapp\\Security\\Headers\\PermissionsPolicy\\*",
                // Rate-limiting algorithms
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                // Password hashing
                "Zappzarapp\\Security\\Password\\Hashing\\*",
                // HTML sanitizer
                "Zappzarapp\\Security\\Sanitization\\Html\\AllowedAttributes::*",
                // HTTP client
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // EQUIVALENT: Empty password returns true (rule satisfied).
                // Without early return, loop finds no matches and returns true anyway.
                // str_contains('', $context) is always false for non-empty context.
                "Zappzarapp\\Security\\Password\\Policy\\Rules\\NoContextRule::isSatisfied",
                // NullCsrfToken - tests run in test environment, cannot test non-test path
                "Zappzarapp\\Security\\Csrf\\Token\\NullCsrfToken::isTestEnvironment",
                // NonceScope end() idempotency - early return is optimization, second call is no-op
                "Zappzarapp\\Security\\Csp\\Nonce\\NonceScope::end",
                // CookieValidator - return after __Host- validation, falls through to __Secure-
                "Zappzarapp\\Security\\Cookie\\CookieValidator::validatePrefixConstraints",
                // Exception truncate - cosmetic return
                "Zappzarapp\\Security\\Cookie\\Exception\\InvalidCookieOptionsException::truncate"
            ]
        },
        "UnwrapStrRepeat": {
            "ignore": [
                // Memory clearing uses str_repeat for null bytes - security critical but hard to observe
                "Zappzarapp\\Security\\Password\\Security\\ClearsMemory::clearMemory"
            ]
        },
        "Continue_": {
            "ignore": [
                // Empty line handling in response parsing - defensive
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedPasswordChecker::*"
            ]
        },
        "Identical": {
            "ignore": [
                // null/false checks in API response handling
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedPasswordChecker::*",
                "Zappzarapp\\Security\\RateLimiting\\Storage\\RedisStorage::*",
                "Zappzarapp\\Security\\RateLimiting\\Storage\\MemcachedStorage::*",
                // Driver check — only testable with SQLite, MySQL branch untestable
                "Zappzarapp\\Security\\RateLimiting\\Storage\\PdoStorage::increment",
                // dns_get_record false check - requires real network with specific
                // failure scenarios. gethostbyname fallback makes this path redundant
                // for most hosts.
                "Zappzarapp\\Security\\Sanitization\\Uri\\NativeDnsResolver::resolveViaDnsGetRecord"
            ]
        },

        // =============================================
        // Type checks and instanceof
        // =============================================
        "InstanceOf_": {
            "ignore": [
                "Zappzarapp\\Security\\Headers\\Builder\\SecurityHeadersBuilder::*",
                "Zappzarapp\\Security\\Password\\Pwned\\PwnedPasswordChecker::*",
                "Zappzarapp\\Security\\Sri\\ResourceFetcher::*"
            ]
        },
        // =============================================
        // Visibility changes - cosmetic, not functional
        // =============================================
        "ProtectedVisibility": {
            "ignore": [
                // Trait methods must be protected for use in subclasses
                "Zappzarapp\\Security\\Password\\Security\\ClearsMemory::*"
            ]
        },
        "NotIdentical": {
            "ignore": [
                "Zappzarapp\\Security\\Cookie\\CookieValidator::validateValue"
            ]
        },

        // =============================================
        // Storage and cleanup - operational, not security
        // =============================================
        "Foreach_": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Storage\\InMemoryStorage::cleanup",
                "Zappzarapp\\Security\\Password\\Validation\\DefaultPasswordValidator::*",
                "Zappzarapp\\Security\\RateLimiting\\RateLimitResult::*"
            ]
        },

        // =============================================
        // Regex patterns - tested at integration level
        // =============================================
        "PregMatchRemoveFlags": {
            "ignore": [
                "Zappzarapp\\Security\\Password\\Strength\\EntropyCalculator::*",
                "Zappzarapp\\Security\\Sri\\IntegrityAttribute::fromString"
            ]
        },

        // =============================================
        // Match expressions
        // =============================================
        "CastString": {
            "ignore": [
                // PDO getAttribute returns string anyway, cast is defensive
                "Zappzarapp\\Security\\RateLimiting\\Storage\\PdoStorage::__construct",
                // PDO binds parameters as strings regardless of explicit cast
                "Zappzarapp\\Security\\RateLimiting\\Storage\\PdoStorage::increment"
            ]
        },
        "MatchArmRemoval": {
            "ignore": [
                "Zappzarapp\\Security\\Sri\\HashAlgorithm::base64Length",
                // URL attribute detection - defense in depth for various element types
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::isUrlAttribute",
                // MySQL match arm in upsert() — untestable without MySQL
                "Zappzarapp\\Security\\RateLimiting\\Storage\\PdoStorage::upsert"
            ]
        },

        // =============================================
        // Regex patterns - semantically equivalent mutations
        // .+ is greedy and matches to end of string anyway
        // =============================================
        "PregMatchRemoveDollar": {
            "ignore": [
                "Zappzarapp\\Security\\Sri\\IntegrityAttribute::fromString",
                // Identifier validation regex
                "Zappzarapp\\Security\\Sanitization\\Sql\\SqlEscaper::*"
            ]
        },

        // =============================================
        // String manipulation - semantically equivalent
        // preg_split already handles leading/trailing whitespace
        // =============================================
        "UnwrapTrim": {
            "ignore": [
                "Zappzarapp\\Security\\Sri\\IntegrityAttribute::fromString",
                // Equivalent: validate() already trims, normalizeForDetection trim is redundant
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::validate",
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::normalizeForDetection"
            ]
        },

        // =============================================
        // Array and string manipulation
        // =============================================
        "SpreadOneItem": {
            "ignore": [
                "Zappzarapp\\Security\\Sri\\IntegrityAttribute::withHash"
            ]
        },
        "ArrayItemRemoval": {
            "ignore": [
                // HTTP context options - all required for proper operation
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // Logging context - cosmetic
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*",
                // Sanitizer config
                "Zappzarapp\\Security\\Sanitization\\Html\\AllowedAttributes::*",
                // Password validation
                "Zappzarapp\\Security\\Password\\Validation\\*"
            ]
        },
        "UnwrapStrReplace": {
            "ignore": [
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*",
                // Deprecated quoteIdentifier and escapeLike methods
                "Zappzarapp\\Security\\Sanitization\\Sql\\SqlEscaper::*",
                // Equivalent: preg_replace already removes null bytes via control character regex
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::normalizeForDetection"
            ]
        },
        "ArrayItem": {
            "ignore": [
                // Logging context - cosmetic
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*"
            ]
        },
        "UnwrapStrToLower": {
            "ignore": [
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::hasBlockedExtension",
                // Equivalent: DOMDocument normalizes tag/attribute names internally
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::sanitizeNode",
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::sanitizeAttributes",
                // Case-insensitive scheme check - uppercase HTTP/HTTPS should work
                // Testing requires real network calls, strtolower is defensive
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::get",
                // ResourceFetcher scheme validation - defensive normalization
                "Zappzarapp\\Security\\Sri\\ResourceFetcher::fetch"
            ]
        },

        // =============================================
        // Control flow
        // =============================================
        "Break_": {
            "ignore": [
                "Zappzarapp\\Security\\Sanitization\\Path\\PathValidator::*"
            ]
        },

        // =============================================
        // Arithmetic
        // =============================================
        "Minus": {
            "ignore": [
                "Zappzarapp\\Security\\Cookie\\SecureCookie::headerValue",
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\RateLimiting\\RateLimitResult::*"
            ]
        },

        // =============================================
        // XML/HTML parsing internals - cleanup functions
        // =============================================
        "FunctionCallRemoval": {
            "ignore": [
                // libxml error handling is cleanup, not affecting behavior
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::parseHtml",
                // SRI hash generator
                "Zappzarapp\\Security\\Sri\\SriHashGenerator::*",
                // Password hashing cleanup
                "Zappzarapp\\Security\\Password\\Hashing\\*",
                // Rate limit results
                "Zappzarapp\\Security\\RateLimiting\\RateLimitResult::*",
                // sodium_memzero is security defense-in-depth, not functionally testable
                "Zappzarapp\\Security\\Password\\Security\\ClearsMemory::clearMemory"
            ]
        },
        "BitwiseOr": {
            "ignore": [
                // LIBXML flags - flags are optional hints to parser
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::parseHtml",
                // html_entity_decode flags - ENT_QUOTES | ENT_HTML5 vs ENT_QUOTES & ENT_HTML5
                // functionally similar for common entities
                "Zappzarapp\\Security\\Sanitization\\Uri\\UriSanitizer::normalizeForDetection",
                // Invalid UTF-8 returns empty string from htmlspecialchars regardless of flags
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::sanitize",
                // CSRF token generation flags
                "Zappzarapp\\Security\\Csrf\\Pattern\\SynchronizerTokenPattern::*",
                // Password hashing flags
                "Zappzarapp\\Security\\Password\\Hashing\\*",
                // SRI hash generator
                "Zappzarapp\\Security\\Sri\\SriHashGenerator::*",
                // DNS_A | DNS_AAAA - requires real network to test. When gethostbyname
                // succeeds, dns_get_record results are duplicates. Can only be killed
                // with IPv6-only hosts where gethostbyname fails but AAAA records exist.
                "Zappzarapp\\Security\\Sanitization\\Uri\\NativeDnsResolver::resolveViaDnsGetRecord"
            ]
        },
        // =============================================
        // Try/finally cleanup - semantically equivalent when no exception is thrown
        // =============================================
        "UnwrapFinally": {
            "ignore": [
                // Memory clearing happens in finally block - defense in depth
                "Zappzarapp\\Security\\Password\\Security\\ClearsMemory::*",
                // file_get_contents doesn't throw, finally is equivalent to sequential code
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // SRI hash generator cleanup
                "Zappzarapp\\Security\\Sri\\SriHashGenerator::*",
                // Password hashing cleanup
                "Zappzarapp\\Security\\Password\\Hashing\\*"
            ]
        },
        "PublicVisibility": {
            "ignore": [
                // Visibility mutations are API-only, not behavior
                "Zappzarapp\\Security\\Password\\Hashing\\*"
            ]
        },
        "LogicalOrAllSubExprNegation": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Storage\\InMemoryStorage::*",
                "Zappzarapp\\Security\\Sanitization\\Html\\HtmlSanitizer::*",
                // NullCsrfToken - tests run in test environment, cannot test non-test path
                "Zappzarapp\\Security\\Csrf\\Token\\NullCsrfToken::isTestEnvironment"
            ]
        },
        "LessThanNegotiation": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\RateLimiting\\Storage\\*"
            ]
        },
        "LogicalNot": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // NullCsrfToken - tests run in test environment, cannot test non-test path
                "Zappzarapp\\Security\\Csrf\\Token\\NullCsrfToken::__construct",
                // InMemoryStorage key limit check
                "Zappzarapp\\Security\\RateLimiting\\Storage\\InMemoryStorage::*"
            ]
        },
        "LogicalOrNegation": {
            "ignore": [
                "Zappzarapp\\Security\\RateLimiting\\Algorithm\\*",
                "Zappzarapp\\Security\\Sri\\FileGetContentsHttpClient::*",
                // NullCsrfToken - tests run in test environment, cannot test non-test path
                "Zappzarapp\\Security\\Csrf\\Token\\NullCsrfToken::isTestEnvironment"
            ]
        },

        // =============================================
        // NullCsrfToken isTestEnvironment() - untestable
        // Tests always run in a test environment, so these paths
        // can never be exercised during test execution
        // =============================================
        "LogicalOrSingleSubExprNegation": {
            "ignore": [
                "Zappzarapp\\Security\\Csrf\\Token\\NullCsrfToken::isTestEnvironment"
            ]
        }
    },
    "minMsi": 100,
    "minCoveredMsi": 100,
    "phpUnit": {
        "configDir": "."
    },
    "timeout": 30,
    "testFramework": "phpunit"
}
