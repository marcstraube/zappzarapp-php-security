{
  "name": "zappzarapp/security",
  "description": "Comprehensive PHP security library: CSP, Security Headers, CSRF, Cookies, Password Validation, Input Sanitization, Rate Limiting, SRI, and Audit Logging",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "security",
    "csp",
    "content-security-policy",
    "csrf",
    "xss",
    "headers",
    "hsts",
    "password",
    "sanitization",
    "rate-limiting",
    "sri",
    "subresource-integrity",
    "audit-logging",
    "php8"
  ],
  "authors": [
    {
      "name": "Marc Straube",
      "email": "email@marcstraube.de"
    }
  ],
  "homepage": "https://github.com/marcstraube/zappzarapp-php-security",
  "support": {
    "issues": "https://github.com/marcstraube/zappzarapp-php-security/issues",
    "source": "https://github.com/marcstraube/zappzarapp-php-security"
  },
  "require": {
    "php": "^8.4",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-sodium": "*"
  },
  "suggest": {
    "psr/log": "For security event audit logging (PSR-3)",
    "psr/http-client": "For PSR-18 HTTP client support in PwnedPasswordChecker",
    "psr/http-factory": "For PSR-17 HTTP factory support in PwnedPasswordChecker",
    "ext-redis": "For Redis rate limit storage (phpredis extension)",
    "predis/predis": "For Redis rate limit storage (pure PHP client)",
    "ext-memcached": "For Memcached rate limit storage"
  },
  "require-dev": {
    "ext-fileinfo": "*",
    "psr/log": "^1.1 || ^3.0",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.1",
    "cyclonedx/cyclonedx-php-composer": "^6.1",
    "ekino/phpstan-banned-code": "^3.0",
    "friendsofphp/php-cs-fixer": "^3.91",
    "phpdocumentor/phpdocumentor": "^3.6",
    "phpmd/phpmd": "^2.15",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.4",
    "rector/rector": "^2.3",
    "roave/security-advisories": "dev-latest",
    "vimeo/psalm": "^6.14",
    "infection/infection": "*",
    "deptrac/deptrac": "^4.5",
    "captainhook/captainhook": "*",
    "captainhook/plugin-composer": "^5.3",
    "giorgiosironi/eris": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "cyclonedx/cyclonedx-php-composer": true,
      "infection/extension-installer": true,
      "captainhook/plugin-composer": true
    },
    "platform": {
      "php": "8.4.3"
    }
  },
  "autoload": {
    "psr-4": {
      "Zappzarapp\\Security\\Csp\\": "src/Csp/",
      "Zappzarapp\\Security\\Headers\\": "src/Headers/",
      "Zappzarapp\\Security\\Csrf\\": "src/Csrf/",
      "Zappzarapp\\Security\\Cookie\\": "src/Cookie/",
      "Zappzarapp\\Security\\Password\\": "src/Password/",
      "Zappzarapp\\Security\\Sanitization\\": "src/Sanitization/",
      "Zappzarapp\\Security\\RateLimiting\\": "src/RateLimiting/",
      "Zappzarapp\\Security\\Sri\\": "src/Sri/",
      "Zappzarapp\\Security\\Logging\\": "src/Logging/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Zappzarapp\\Security\\Tests\\Csp\\": "tests/Csp/",
      "Zappzarapp\\Security\\Tests\\Headers\\": "tests/Headers/",
      "Zappzarapp\\Security\\Tests\\Csrf\\": "tests/Csrf/",
      "Zappzarapp\\Security\\Tests\\Cookie\\": "tests/Cookie/",
      "Zappzarapp\\Security\\Tests\\Password\\": "tests/Password/",
      "Zappzarapp\\Security\\Tests\\Sanitization\\": "tests/Sanitization/",
      "Zappzarapp\\Security\\Tests\\RateLimiting\\": "tests/RateLimiting/",
      "Zappzarapp\\Security\\Tests\\Sri\\": "tests/Sri/",
      "Zappzarapp\\Security\\Tests\\Logging\\": "tests/Logging/"
    }
  },
  "scripts": {
    "test": "@php vendor/bin/phpunit",
    "analyse": "@php vendor/bin/phpstan analyse",
    "psalm": "@php vendor/bin/psalm --show-info=false",
    "phpmd": "@php vendor/bin/phpmd src,tests text phpmd.xml",
    "rector": "@php vendor/bin/rector process --dry-run",
    "rector-fix": "@php vendor/bin/rector process",
    "infection": "@php vendor/bin/infection --threads=4",
    "deptrac": "@php vendor/bin/deptrac analyse",
    "security": "composer audit --no-dev",
    "sbom": "@composer CycloneDX:make-sbom --output-file=sbom.json",
    "cs-fix": "@php vendor/bin/php-cs-fixer fix",
    "cs-check": "@php vendor/bin/php-cs-fixer fix --dry-run --diff",
    "docs": "@php vendor/bin/phpdoc",
    "check": [
      "@security",
      "@cs-check",
      "@analyse",
      "@psalm",
      "@phpmd",
      "@rector",
      "@deptrac",
      "@test"
    ],
    "check-full": [
      "@check",
      "@infection"
    ]
  }
}
